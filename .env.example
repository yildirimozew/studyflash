# Database (Supabase connection string - use the "Direct connection" URL from Supabase)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# NextAuth
NEXTAUTH_SECRET="generate-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional -- demo mode if absent)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Groq AI (llama-3.3-70b-versatile) - get a free key at https://console.groq.com
GROQ_API_KEY=""

# Gmail API (optional -- sync disabled if absent)
# GMAIL_ADDRESS: the Gmail inbox to poll (e.g. support@studyflash.ch)
# GMAIL_REFRESH_TOKEN: run `npx tsx scripts/get-gmail-token.ts` to obtain
GMAIL_ADDRESS=""
GMAIL_REFRESH_TOKEN=""

# Demo mode (bypass auth, use seed data)
DEMO_MODE="true"
NEXT_PUBLIC_DEMO_MODE="true"
